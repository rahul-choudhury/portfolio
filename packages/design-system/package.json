{
  "name": "@workspace/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "default": "./src/ui/*.tsx"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*"
  }
}
