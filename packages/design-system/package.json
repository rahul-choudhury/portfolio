{
  "name": "@workspace/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./next": {
      "types": "./src/next/index.ts",
      "default": "./src/next/index.ts"
    },
    "./tokens.css": "./src/styles/tokens.css"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": "^16.0.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@workspace/typescript-config": "workspace:*"
  }
}
