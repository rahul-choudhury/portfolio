    "db:migrate": "NODE_ENV=production drizzle-kit migrate"
  },
  "dependencies": {
    "@workspace/design-system": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "0.45.1",
    "next": "16.0.10",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "unfurl.js": "^6.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "16.0.10",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.2.3",
    "@workspace/typescript-config": "workspace:*",
    "baseline-browser-mapping": "^2.10.0",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.2.2"
